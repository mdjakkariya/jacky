# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# Real environment variables override these.

# Web search (opt-in, off-device). Get a key at https://www.searchspace.io/console
# AUTOBOT_ALLOW_WEB=0
# AUTOBOT_WEB_API_KEY=your-searchspace-key-here
# AUTOBOT_WEB_PROVIDER=auto          # auto | searchspace | ddgs
# AUTOBOT_WEB_API_URL=https://q.searchspace.io/v1/search

# Debugging
# AUTOBOT_SAVE_AUDIO=1               # save each captured clip as a WAV in sessions/
# AUTOBOT_DEBUG=1                    # print per-turn token/compaction lines
# AUTOBOT_SESSION_LOG=1              # write the per-session transcript

# App control (macOS) — let Jack open/focus/quit/etc. apps by voice. On by
# default; uninstall always asks for confirmation. Set to 0 to disable the tools.
# AUTOBOT_ALLOW_APPS=1

# Daemon (Phase 3c) — localhost API for UI clients (floating orb / terminal).
# Bind stays loopback by design. Run with `python -m autobot.daemon` (or --demo).
# AUTOBOT_DAEMON_HOST=127.0.0.1
# AUTOBOT_DAEMON_PORT=8765

# Other handy overrides (see src/autobot/config.py for all):
# AUTOBOT_LLM_MODEL=qwen3:8b
# AUTOBOT_STT_MODEL=small.en
# AUTOBOT_TTS_VOICE=~/.autobot/voices/en_US-ryan-high.onnx
# AUTOBOT_FOLLOWUP_WINDOW_S=30
