<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Core Audio process taps capture system audio; this entitlement + a
         Developer ID signature + the Info.plist NSAudioCaptureUsageDescription
         are what make the "Audio Capture" TCC prompt fire. Unsigned dev builds
         run but the prompt won't appear (capture silently degrades). -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
